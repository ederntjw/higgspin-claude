# Higgsfield credentials — get from https://cloud.higgsfield.ai/ → Settings
# Format is "key:secret" combined, OR set HF_API_KEY + HF_API_SECRET separately.
HF_KEY=your_higgsfield_key:your_higgsfield_secret

# Pinterest login — used by scripts/pinterest_scrape.py
# First run will open a visible Chrome; complete any CAPTCHA once, session is cached.
PINTEREST_EMAIL=you@example.com
PINTEREST_PASSWORD=your_pinterest_password

# Anthropic API key — only needed if you call Claude vision from Python instead
# of letting Claude Code do it natively. Optional.
ANTHROPIC_API_KEY=
