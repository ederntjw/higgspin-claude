# Pinterest login — used by scripts/pinterest_scrape.py to scrape moodboard pins.
# First run will open a visible Chrome; complete any CAPTCHA once, session is cached.
PINTEREST_EMAIL=you@example.com
PINTEREST_PASSWORD=your_pinterest_password

# -----------------------------------------------------------------------------
# Higgsfield auth — choose ONE of the two paths below. You don't need both.
# -----------------------------------------------------------------------------

# Path A (recommended) — use the Higgsfield MCP via Claude Code.
# In Claude Code, run:
#     claude mcp add --transport http higgsfield https://mcp.higgsfield.ai/mcp
# then `/mcp` and OAuth. No values needed in this file for Higgsfield.

# Path B (fallback) — use the Higgsfield Python SDK / raw HTTP.
# Get the key from https://cloud.higgsfield.ai/ → Settings → API Keys.
# Format is "key:secret" combined, OR set HF_API_KEY + HF_API_SECRET separately.
# HF_KEY=your_higgsfield_key:your_higgsfield_secret

# -----------------------------------------------------------------------------

# Anthropic API key — only needed if you call Claude vision from Python instead
# of letting Claude Code do it natively. Optional.
ANTHROPIC_API_KEY=
